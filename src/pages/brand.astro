---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Brand — Lucas Sommer" description="The design system, brand elements, and settings for lucassommer.com. A living style guide you can interact with.">

  <section class="brand-hero container">
    <div class="brand-badge">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" width="14" height="14"><path d="M12.22 2h-.44a2 2 0 00-2 2v.18a2 2 0 01-1 1.73l-.43.25a2 2 0 01-2 0l-.15-.08a2 2 0 00-2.73.73l-.22.38a2 2 0 00.73 2.73l.15.1a2 2 0 011 1.72v.51a2 2 0 01-1 1.74l-.15.09a2 2 0 00-.73 2.73l.22.38a2 2 0 002.73.73l.15-.08a2 2 0 012 0l.43.25a2 2 0 011 1.73V20a2 2 0 002 2h.44a2 2 0 002-2v-.18a2 2 0 011-1.73l.43-.25a2 2 0 012 0l.15.08a2 2 0 002.73-.73l.22-.39a2 2 0 00-.73-2.73l-.15-.08a2 2 0 01-1-1.74v-.5a2 2 0 011-1.74l.15-.09a2 2 0 00.73-2.73l-.22-.38a2 2 0 00-2.73-.73l-.15.08a2 2 0 01-2 0l-.43-.25a2 2 0 01-1-1.73V4a2 2 0 00-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
      Brand Settings
    </div>
    <h1>lucas sommer</h1>
    <p class="brand-intro">The design system, brand elements, and live settings for this site. Everything here is public. Change settings and watch the site update in real time.</p>
  </section>

  <!-- Live Settings Panel -->
  <section class="container">
    <div class="section-header">
      <h2>Settings</h2>
      <span class="section-meta">Adjust the site in real time</span>
    </div>
    <div class="settings-grid">

      <div class="setting-card">
        <div class="setting-label">Theme</div>
        <div class="setting-control">
          <button class="setting-btn" data-setting="theme" data-value="dark">Dark</button>
          <button class="setting-btn" data-setting="theme" data-value="light">Light</button>
        </div>
      </div>

      <div class="setting-card">
        <div class="setting-label">Accent Color</div>
        <div class="setting-control accent-swatches">
          <button class="swatch active" data-setting="accent" data-value="blue" style="background:#3b82f6;" title="Blue"></button>
          <button class="swatch" data-setting="accent" data-value="violet" style="background:#8b5cf6;" title="Violet"></button>
          <button class="swatch" data-setting="accent" data-value="emerald" style="background:#10b981;" title="Emerald"></button>
          <button class="swatch" data-setting="accent" data-value="rose" style="background:#f43f5e;" title="Rose"></button>
          <button class="swatch" data-setting="accent" data-value="amber" style="background:#f59e0b;" title="Amber"></button>
          <button class="swatch" data-setting="accent" data-value="cyan" style="background:#06b6d4;" title="Cyan"></button>
        </div>
      </div>

      <div class="setting-card">
        <div class="setting-label">Font Size</div>
        <div class="setting-control">
          <button class="setting-btn" data-setting="size" data-value="compact">Compact</button>
          <button class="setting-btn" data-setting="size" data-value="default">Default</button>
          <button class="setting-btn" data-setting="size" data-value="large">Large</button>
        </div>
      </div>

      <div class="setting-card">
        <div class="setting-label">Border Radius</div>
        <div class="setting-control">
          <button class="setting-btn" data-setting="radius" data-value="sharp">Sharp</button>
          <button class="setting-btn" data-setting="radius" data-value="default">Default</button>
          <button class="setting-btn" data-setting="radius" data-value="round">Round</button>
        </div>
      </div>

      <div class="setting-card setting-card-wide">
        <div class="setting-label">Reset</div>
        <div class="setting-control">
          <button class="setting-btn setting-btn-reset" id="reset-all">Reset to defaults</button>
        </div>
      </div>

    </div>
  </section>

  <!-- Color Palette -->
  <section class="container">
    <div class="section-header">
      <h2>Color Palette</h2>
      <span class="section-meta">Current theme tokens</span>
    </div>

    <div class="palette-section">
      <h3>Surfaces</h3>
      <div class="palette-row">
        <div class="color-chip">
          <div class="chip-swatch" style="background:var(--bg);"></div>
          <div class="chip-info">
            <span class="chip-name">Background</span>
            <code class="chip-value">--bg</code>
          </div>
        </div>
        <div class="color-chip">
          <div class="chip-swatch" style="background:var(--surface-1);"></div>
          <div class="chip-info">
            <span class="chip-name">Surface 1</span>
            <code class="chip-value">--surface-1</code>
          </div>
        </div>
        <div class="color-chip">
          <div class="chip-swatch" style="background:var(--surface-2);"></div>
          <div class="chip-info">
            <span class="chip-name">Surface 2</span>
            <code class="chip-value">--surface-2</code>
          </div>
        </div>
        <div class="color-chip">
          <div class="chip-swatch" style="background:var(--surface-3);"></div>
          <div class="chip-info">
            <span class="chip-name">Surface 3</span>
            <code class="chip-value">--surface-3</code>
          </div>
        </div>
      </div>
    </div>

    <div class="palette-section">
      <h3>Text</h3>
      <div class="palette-row">
        <div class="color-chip">
          <div class="chip-swatch" style="background:var(--text-primary);"></div>
          <div class="chip-info">
            <span class="chip-name">Primary</span>
            <code class="chip-value">--text-primary</code>
          </div>
        </div>
        <div class="color-chip">
          <div class="chip-swatch" style="background:var(--text-secondary);"></div>
          <div class="chip-info">
            <span class="chip-name">Secondary</span>
            <code class="chip-value">--text-secondary</code>
          </div>
        </div>
        <div class="color-chip">
          <div class="chip-swatch" style="background:var(--text-tertiary);"></div>
          <div class="chip-info">
            <span class="chip-name">Tertiary</span>
            <code class="chip-value">--text-tertiary</code>
          </div>
        </div>
      </div>
    </div>

    <div class="palette-section">
      <h3>Accent & Status</h3>
      <div class="palette-row">
        <div class="color-chip">
          <div class="chip-swatch" style="background:var(--accent);"></div>
          <div class="chip-info">
            <span class="chip-name">Accent</span>
            <code class="chip-value">--accent</code>
          </div>
        </div>
        <div class="color-chip">
          <div class="chip-swatch" style="background:var(--status-active-text);"></div>
          <div class="chip-info">
            <span class="chip-name">Active</span>
            <code class="chip-value">--status-active</code>
          </div>
        </div>
        <div class="color-chip">
          <div class="chip-swatch" style="background:var(--status-building-text);"></div>
          <div class="chip-info">
            <span class="chip-name">Building</span>
            <code class="chip-value">--status-building</code>
          </div>
        </div>
        <div class="color-chip">
          <div class="chip-swatch" style="background:var(--status-exploring-text);"></div>
          <div class="chip-info">
            <span class="chip-name">Exploring</span>
            <code class="chip-value">--status-exploring</code>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Typography -->
  <section class="container">
    <div class="section-header">
      <h2>Typography</h2>
      <span class="section-meta">Bricolage Grotesque (display) + Inter (body) + JetBrains Mono</span>
    </div>
    <div class="type-samples">
      <div class="type-row">
        <code class="type-spec">3rem / 800 / -1.5px</code>
        <div class="type-sample" style="font-size:3rem; font-weight:800; letter-spacing:-1.5px; line-height:1.0;">Display headline</div>
      </div>
      <div class="type-row">
        <code class="type-spec">2.25rem / 700 / -1px</code>
        <div class="type-sample" style="font-size:2.25rem; font-weight:700; letter-spacing:-1px; line-height:1.1;">Section heading</div>
      </div>
      <div class="type-row">
        <code class="type-spec">1.5rem / 700 / -0.5px</code>
        <div class="type-sample" style="font-size:1.5rem; font-weight:700; letter-spacing:-0.5px; line-height:1.2;">Card title</div>
      </div>
      <div class="type-row">
        <code class="type-spec">1.125rem / 600 / -0.2px</code>
        <div class="type-sample" style="font-size:1.125rem; font-weight:600; letter-spacing:-0.2px; line-height:1.3;">Smaller heading</div>
      </div>
      <div class="type-row">
        <code class="type-spec">0.9375rem / 400 / normal</code>
        <div class="type-sample" style="font-size:0.9375rem; font-weight:400; line-height:1.6; color:var(--text-secondary);">Body text — the standard reading size used for descriptions, paragraphs, and general content across the site.</div>
      </div>
      <div class="type-row">
        <code class="type-spec">mono / 0.75rem / 500</code>
        <div class="type-sample" style="font-family:var(--font-mono); font-size:0.75rem; font-weight:500; color:var(--text-tertiary);">Monospace — used for stat numbers, site name, technical labels, version tags</div>
      </div>
    </div>
  </section>

  <!-- Components -->
  <section class="container">
    <div class="section-header">
      <h2>Components</h2>
      <span class="section-meta">Buttons, badges, cards, tags</span>
    </div>

    <div class="components-grid">
      <div class="component-block">
        <h3>Buttons</h3>
        <div class="component-row">
          <button class="demo-btn demo-btn-primary">Get updates</button>
          <button class="demo-btn demo-btn-ghost">Learn more</button>
          <button class="demo-btn demo-btn-subtle">Cancel</button>
        </div>
      </div>

      <div class="component-block">
        <h3>Status Badges</h3>
        <div class="component-row">
          <span class="demo-status demo-status-active">Active</span>
          <span class="demo-status demo-status-building">Building</span>
          <span class="demo-status demo-status-exploring">Exploring</span>
        </div>
      </div>

      <div class="component-block">
        <h3>Tags</h3>
        <div class="component-row">
          <span class="demo-tag">AI</span>
          <span class="demo-tag">Marketing</span>
          <span class="demo-tag">SaaS</span>
          <span class="demo-tag">Construction</span>
          <span class="demo-tag">Wine</span>
          <span class="demo-tag">Finance</span>
        </div>
      </div>

      <div class="component-block">
        <h3>Card</h3>
        <div class="demo-card">
          <div class="demo-card-icon">Ex</div>
          <div class="demo-card-body">
            <div class="demo-card-top">
              <span class="demo-card-name">Example Project</span>
              <span class="demo-status demo-status-building">Building</span>
            </div>
            <p class="demo-card-desc">This is how project cards look throughout the site. Hover to see the interaction state.</p>
            <div class="component-row" style="margin-top:0.5rem;">
              <span class="demo-tag">Example</span>
              <span class="demo-tag">Demo</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Brand Info -->
  <section class="container">
    <div class="section-header">
      <h2>About the Brand</h2>
    </div>
    <div class="brand-info">
      <div class="info-card">
        <h3>Philosophy</h3>
        <p>Assets over income. Time is the scarcest resource. Execution is everything. Seek the margin. Build in public.</p>
      </div>
      <div class="info-card">
        <h3>Background</h3>
        <p>Serial entrepreneur and operator. University of Miami (Finance + Music). MBA in Entrepreneurship. Member, Young Entrepreneur Council.</p>
      </div>
      <div class="info-card">
        <h3>Companies</h3>
        <p>Audimated (NBC, Forbes, WeMedia winner) &middot; Socialated (acquired) &middot; Ad-Apt &middot; Boss PDX &middot; Grove Vineyard &middot; Halem Heights &middot; IntraAlpha &middot; Carcin.ai &middot; Del Toro Shoes</p>
      </div>
      <div class="info-card">
        <h3>Press</h3>
        <p>Forbes &middot; NBC News &middot; Entrepreneur.com &middot; Reuters &middot; Georgetown University &middot; MarketingProfs &middot; StartupNation</p>
      </div>
    </div>
  </section>

  <div style="height:5rem;"></div>

</BaseLayout>

<script>
  // Accent color definitions
  const accents: Record<string, { accent: string; hover: string; soft: string; text: string; textLight: string }> = {
    blue:    { accent: '#3b82f6', hover: '#2563eb', soft: 'rgba(59,130,246,0.1)',  text: '#60a5fa', textLight: '#2563eb' },
    violet:  { accent: '#8b5cf6', hover: '#7c3aed', soft: 'rgba(139,92,246,0.1)', text: '#a78bfa', textLight: '#7c3aed' },
    emerald: { accent: '#10b981', hover: '#059669', soft: 'rgba(16,185,129,0.1)', text: '#34d399', textLight: '#059669' },
    rose:    { accent: '#f43f5e', hover: '#e11d48', soft: 'rgba(244,63,94,0.1)',  text: '#fb7185', textLight: '#e11d48' },
    amber:   { accent: '#f59e0b', hover: '#d97706', soft: 'rgba(245,158,11,0.1)', text: '#fbbf24', textLight: '#d97706' },
    cyan:    { accent: '#06b6d4', hover: '#0891b2', soft: 'rgba(6,182,212,0.1)',  text: '#22d3ee', textLight: '#0891b2' },
  };

  function applySettings() {
    const theme = localStorage.getItem('theme') || 'dark';
    const accent = localStorage.getItem('accent') || 'blue';
    const size = localStorage.getItem('fontSize') || 'default';
    const radius = localStorage.getItem('radius') || 'default';

    // Theme
    if (theme === 'light') document.documentElement.setAttribute('data-theme', 'light');
    else document.documentElement.removeAttribute('data-theme');

    // Accent
    const a = accents[accent] || accents.blue;
    const isLight = theme === 'light';
    document.documentElement.style.setProperty('--accent', a.accent);
    document.documentElement.style.setProperty('--accent-hover', a.hover);
    document.documentElement.style.setProperty('--accent-soft', a.soft);
    document.documentElement.style.setProperty('--accent-text', isLight ? a.textLight : a.text);

    // Font size
    const sizes: Record<string, string> = { compact: '14px', default: '15px', large: '17px' };
    document.documentElement.style.fontSize = sizes[size] || '15px';

    // Border radius
    const radii: Record<string, string[]> = {
      sharp:   ['4px', '2px', '1px'],
      default: ['12px', '8px', '4px'],
      round:   ['20px', '14px', '8px'],
    };
    const r = radii[radius] || radii.default;
    document.documentElement.style.setProperty('--radius', r[0]);
    document.documentElement.style.setProperty('--radius-sm', r[1]);
    document.documentElement.style.setProperty('--radius-xs', r[2]);

    // Update active states on buttons
    document.querySelectorAll('[data-setting="theme"]').forEach(b => {
      (b as HTMLElement).classList.toggle('active', (b as HTMLElement).dataset.value === theme);
    });
    document.querySelectorAll('[data-setting="accent"]').forEach(b => {
      (b as HTMLElement).classList.toggle('active', (b as HTMLElement).dataset.value === accent);
    });
    document.querySelectorAll('[data-setting="size"]').forEach(b => {
      (b as HTMLElement).classList.toggle('active', (b as HTMLElement).dataset.value === size);
    });
    document.querySelectorAll('[data-setting="radius"]').forEach(b => {
      (b as HTMLElement).classList.toggle('active', (b as HTMLElement).dataset.value === radius);
    });
  }

  // Bind setting buttons
  document.querySelectorAll('[data-setting]').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      const setting = el.dataset.setting!;
      const value = el.dataset.value!;

      const keys: Record<string, string> = { theme: 'theme', accent: 'accent', size: 'fontSize', radius: 'radius' };
      localStorage.setItem(keys[setting], value);
      applySettings();
    });
  });

  document.getElementById('reset-all')?.addEventListener('click', () => {
    localStorage.removeItem('theme');
    localStorage.removeItem('accent');
    localStorage.removeItem('fontSize');
    localStorage.removeItem('radius');
    document.documentElement.removeAttribute('data-theme');
    document.documentElement.style.removeProperty('--accent');
    document.documentElement.style.removeProperty('--accent-hover');
    document.documentElement.style.removeProperty('--accent-soft');
    document.documentElement.style.removeProperty('--accent-text');
    document.documentElement.style.removeProperty('--radius');
    document.documentElement.style.removeProperty('--radius-sm');
    document.documentElement.style.removeProperty('--radius-xs');
    document.documentElement.style.fontSize = '';
    applySettings();
  });

  // Apply on load
  applySettings();
</script>

<style>
  /* ---- Hero ---- */
  .brand-hero { padding-top: 5rem; padding-bottom: 1rem; }

  .brand-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--surface-1);
    border: 1px solid var(--border);
    padding: 0.3rem 0.85rem 0.3rem 0.65rem;
    border-radius: 9999px;
    margin-bottom: 1.5rem;
  }

  .brand-hero h1 {
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -1.5px;
    line-height: 1.0;
    font-family: var(--font-mono);
    margin-bottom: 1rem;
  }

  .brand-intro {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 600px;
    line-height: 1.7;
  }

  /* ---- Settings Panel ---- */
  .settings-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    padding-bottom: 2rem;
  }

  .setting-card {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }

  .setting-card-wide { grid-column: 1 / -1; }

  .setting-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
    margin-bottom: 0.75rem;
  }

  .setting-control {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .setting-btn {
    background: var(--surface-2);
    color: var(--text-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.4rem 0.85rem;
    font-family: inherit;
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .setting-btn:hover {
    border-color: var(--border-hover);
    color: var(--text-primary);
  }

  .setting-btn.active {
    background: var(--accent);
    color: #ffffff;
    border-color: var(--accent);
  }

  .setting-btn-reset {
    background: transparent;
    color: var(--text-tertiary);
    border-color: var(--border);
  }

  .setting-btn-reset:hover { color: var(--text-primary); }

  /* Accent swatches */
  .accent-swatches { gap: 0.5rem; }

  .swatch {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    transition: border-color 0.15s ease, transform 0.15s ease;
    padding: 0;
  }

  .swatch:hover { transform: scale(1.1); }
  .swatch.active { border-color: var(--text-primary); transform: scale(1.15); }

  /* ---- Color Palette ---- */
  .palette-section { margin-bottom: 2rem; }
  .palette-section h3 {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .palette-row {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.75rem;
  }

  .color-chip {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: border-color 0.15s ease;
  }

  .chip-swatch {
    height: 56px;
    border-bottom: 1px solid var(--border);
  }

  .chip-info {
    padding: 0.6rem 0.75rem;
  }

  .chip-name {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.1rem;
  }

  .chip-value {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
  }

  /* ---- Typography ---- */
  .type-samples { padding-bottom: 2rem; }

  .type-row {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
  }

  .type-row:last-child { border-bottom: none; }

  .type-spec {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    display: block;
    margin-bottom: 0.4rem;
  }

  .type-sample {
    color: var(--text-primary);
  }

  /* ---- Components ---- */
  .components-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-bottom: 2rem;
  }

  .component-block h3 {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .component-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* Demo buttons */
  .demo-btn {
    font-family: inherit;
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.55rem 1.15rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .demo-btn-primary {
    background: var(--accent);
    color: #fff;
    border: none;
  }
  .demo-btn-primary:hover { background: var(--accent-hover); }

  .demo-btn-ghost {
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border);
  }
  .demo-btn-ghost:hover { border-color: var(--border-hover); color: var(--text-primary); }

  .demo-btn-subtle {
    background: transparent;
    color: var(--text-tertiary);
    border: 1px solid transparent;
  }
  .demo-btn-subtle:hover { color: var(--text-secondary); }

  /* Demo status badges */
  .demo-status {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
