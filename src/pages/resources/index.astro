---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Resources — Lucas Sommer" description="Free tools, frameworks, and guides from Lucas Sommer.">
  <section class="resources container">
    <div class="resources-hero">
      <h1>Resources</h1>
      <p class="intro">Free tools and frameworks I've built or found useful. Take them, use them, make them better.</p>
    </div>

    <div class="resource-list">
      <a class="resource-card" href="/resources/ideation-flow">
        <div class="resource-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" width="20" height="20"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
        </div>
        <div class="resource-body">
          <h3>Evaluating Ideas and Problems to Solve</h3>
          <p>A framework for sizing opportunities by finding the biggest margin between what the market pays and what it costs you to deliver. Includes an interactive worksheet.</p>
          <span class="resource-type">Framework + Worksheet</span>
        </div>
      </a>
    </div>

  </section>
</BaseLayout>

<style>
  .resources-hero {
    padding-top: 4rem;
    padding-bottom: 2rem;
  }

  .resources-hero h1 {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -1.5px;
    margin-bottom: 0.75rem;
  }

  .intro {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 600px;
    line-height: 1.7;
  }

  .resource-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-bottom: 4rem;
  }

  .resource-card {
    display: flex;
    gap: 1.15rem;
    padding: 1.35rem;
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }

  .resource-card:hover {
    border-color: var(--border-hover);
    background: var(--surface-2);
    color: inherit;
  }

  .resource-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: var(--accent-soft);
    color: var(--accent-text);
  }

  .resource-body {
    flex: 1;
    min-width: 0;
  }

  .resource-body h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.2px;
    margin-bottom: 0.35rem;
  }

  .resource-body p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.55;
    margin-bottom: 0.5rem;
  }

  .resource-type {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
  }

  @media (max-width: 640px) {
    .resources-hero { padding-top: 3rem; }
    .resources-hero h1 { font-size: 1.75rem; }
    .intro { font-size: 1rem; }
    .resource-card { padding: 1.15rem; gap: 0.85rem; }
    .resource-icon { width: 38px; height: 38px; }
  }
</style>
