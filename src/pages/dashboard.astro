  .be-ring-key { display: flex; flex-direction: column; gap: 0.35rem; }
  .be-r-row { display: flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono); font-size: 0.75rem; }
  .be-r-dot { width: 14px; height: 14px; border-radius: 50%; border: 1px solid var(--border); }
  .be-help { font-size: 0.75rem; color: var(--text-tertiary); line-height: 1.5; }
  @media (max-width: 740px) { .be-wrap { grid-template-columns: 1fr; } }

  /* Heatmap */
  .hm-help { font-size: 0.8125rem; color: var(--text-tertiary); margin-bottom: 0.75rem; }
  .hm-table { border-collapse: separate; border-spacing: 4px; width: 100%; }
  .hm-table th {
    font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--text-tertiary); text-align: left; padding: 0.4rem 0.5rem;
  }
  .hm-row-label { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-secondary); white-space: nowrap; }
  .hm-cell {
    text-align: center; font-family: var(--font-mono); font-size: 0.8125rem; font-weight: 600;
    color: var(--text-primary); cursor: pointer; border-radius: var(--radius-sm);
    padding: 0.85rem 0.5rem; min-width: 60px;
    transition: outline 0.12s ease;
  }
  .hm-cell:hover { outline: 1px solid var(--accent); }
  .hm-total {
    font-family: var(--font-mono); font-size: 0.75rem; font-weight: 600;
    color: var(--text-tertiary); text-align: center;
  }

  /* Drawer */
  .drawer { position: fixed; inset: 0; z-index: 250; }
