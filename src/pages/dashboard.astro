  .kb-head { display: flex; justify-content: space-between; align-items: center; padding: 0.1rem 0.35rem 0.6rem; border-bottom: 1px solid var(--border); margin-bottom: 0.6rem; }
  .kb-name { font-family: var(--font-mono); font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-secondary); }
  .kb-count { font-family: var(--font-mono); font-size: 0.6875rem; color: var(--text-tertiary); }
  .kb-body { display: flex; flex-direction: column; gap: 0.6rem; }
  .kb-body .task-card { padding: 0.75rem; }

  /* Group-by picker */
  .group-pick { display: flex; align-items: center; gap: 0.4rem; font-size: 0.8125rem; color: var(--text-tertiary); }
  .group-pick[hidden] { display: none; }
  .group-pick select {
    font-family: var(--font-mono); font-size: 0.8125rem; color: var(--text-primary);
    background: var(--surface-1); border: 1px solid var(--border); border-radius: var(--radius-sm);
    padding: 0.4rem 0.6rem; cursor: pointer;
