  /* Bullseye */
  .be-wrap {
    display: grid; grid-template-columns: 1fr 220px; gap: 1.25rem;
    align-items: center; background: var(--surface-1);
    border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem;
  }
  .be-svg-wrap { min-width: 0; }
