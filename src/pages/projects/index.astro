---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Projects — Lucas Sommer" description="Companies, products, and ventures Lucas Sommer is building across marketing, construction, wine, fintech, and AI.">

  <section class="container">
    <div class="projects-hero">
      <h1>Projects</h1>
      <p class="projects-intro">Companies I've built, am building, or am exploring — across marketing, construction, wine, fintech, and AI. Full profiles, numbers, and case studies are gated for now.</p>
      <p class="projects-gate-note"><a href="/unlock/?next=/projects/">Get access</a> to the deep dives.</p>
    </div>

    <div class="projects-grid">

      <div class="project-card">
        <div class="project-icon" style="background:var(--status-building-bg); color:var(--status-building-text);">Ca</div>
        <div class="project-body">
          <div class="project-top">
            <div class="project-name">Carcin.ai</div>
            <span class="project-status status-building">Building</span>
          </div>
          <p class="project-desc">An AI platform for how small businesses show up online.</p>
        </div>
      </div>

      <div class="project-card">
        <div class="project-icon" style="background:rgba(124,58,237,0.12); color:#a78bfa;">Aa</div>
        <div class="project-body">
          <div class="project-top">
            <div class="project-name">Ad-Apt</div>
            <span class="project-status status-active">Active</span>
          </div>
          <p class="project-desc">A digital marketing shop working with a short list of consumer brands.</p>
        </div>
      </div>

      <div class="project-card">
        <div class="project-icon" style="background:var(--status-exploring-bg); color:var(--status-exploring-text);">BP</div>
        <div class="project-body">
          <div class="project-top">
            <div class="project-name">Boss PDX</div>
            <span class="project-status status-active">Active</span>
          </div>
          <p class="project-desc">A Portland-based residential + commercial builder, run with modern tooling.</p>
        </div>
      </div>

      <div class="project-card">
        <div class="project-icon" style="background:var(--status-active-bg); color:var(--status-active-text);">GV</div>
        <div class="project-body">
          <div class="project-top">
            <div class="project-name">Grove Vineyard</div>
            <span class="project-status status-active">Active</span>
          </div>
          <p class="project-desc">An estate vineyard in the Willamette Valley.</p>
        </div>
      </div>

      <div class="project-card">
        <div class="project-icon" style="background:rgba(168,85,247,0.12); color:#c084fc;">HH</div>
        <div class="project-body">
          <div class="project-top">
            <div class="project-name">Halem Heights</div>
            <span class="project-status status-active">Active</span>
          </div>
          <p class="project-desc">A wine brand and hospitality property tied to the same land.</p>
        </div>
      </div>

      <div class="project-card">
        <div class="project-icon" style="background:rgba(219,39,119,0.12); color:#f472b6;">IA</div>
        <div class="project-body">
          <div class="project-top">
            <div class="project-name">IntraAlpha</div>
            <span class="project-status status-exploring">Transitioning</span>
          </div>
          <p class="project-desc">A market-data + trading tooling project. Shape currently shifting.</p>
        </div>
      </div>

      <div class="project-card">
        <div class="project-icon" style="background:var(--surface-2); font-size:1.35rem;">&#x1F412;</div>
        <div class="project-body">
          <div class="project-top">
            <div class="project-name">Monkey Business</div>
            <span class="project-status status-building">Writing</span>
          </div>
          <p class="project-desc">A book, in progress. On why running a business is harder than it should be.</p>
        </div>
      </div>

    </div>

    <div class="projects-past">
      <div class="section-header">
        <h2>Past Ventures</h2>
        <span class="section-meta">Exited or completed</span>
      </div>
      <div class="past-grid">
        <div class="past-card">
          <div class="past-name">Socialated</div>
          <div class="past-detail">A social media agency, built and later exited.</div>
        </div>
        <div class="past-card">
          <div class="past-name">Audimated</div>
          <div class="past-detail">A music-industry platform. Won a national pitch competition. Coverage in Forbes and NBC News.</div>
        </div>
        <div class="past-card">
          <div class="past-name">Del Toro Shoes</div>
          <div class="past-detail">A footwear brand out of Miami, partner role.</div>
        </div>
      </div>
    </div>

  </section>

</BaseLayout>

<style>
  .projects-hero {
    padding-top: 4rem;
    padding-bottom: 1rem;
  }

  .projects-hero h1 {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -1.5px;
    margin-bottom: 0.75rem;
  }

  .projects-intro {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 600px;
    line-height: 1.7;
  }

  .projects-gate-note {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    margin-top: 0.5rem;
  }

  .projects-gate-note a {
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border);
  }

  .projects-gate-note a:hover {
    color: var(--text-primary);
    border-bottom-color: var(--text-primary);
  }

  /* Section Headers */
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 3rem 0 1.25rem;
  }

  .section-meta {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
  }

  /* Project Cards */
  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem 0;
  }

  .project-card {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.35rem;
    display: flex;
    gap: 1.15rem;
    color: inherit;
  }

  .project-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 700;
    flex-shrink: 0;
    font-family: var(--font-mono);
  }

  .project-body { flex: 1; min-width: 0; }

  .project-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.25rem;
  }

  .project-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.2px;
  }

  .project-status {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .status-active { background: var(--status-active-bg); color: var(--status-active-text); }
  .status-building { background: var(--status-building-bg); color: var(--status-building-text); }
  .status-exploring { background: var(--status-exploring-bg); color: var(--status-exploring-text); }

  .project-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.55;
    margin-bottom: 0;
  }

  /* Past Ventures */
  .projects-past {
    padding-bottom: 4rem;
  }

  .past-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .past-card {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }

  .past-name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.35rem;
  }

  .past-detail {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .projects-hero { padding-top: 3rem; }
    .projects-hero h1 { font-size: 1.75rem; }
    .projects-intro { font-size: 1rem; }

    .project-card { padding: 1.15rem; gap: 0.85rem; }
    .project-icon { width: 38px; height: 38px; font-size: 0.95rem; border-radius: 8px; }
    .project-top { flex-direction: column; gap: 0.25rem; }
    .project-status { align-self: flex-start; }
    .project-desc { font-size: 0.8125rem; }

    .section-meta { display: none; }
    .past-grid { grid-template-columns: 1fr; }
  }
</style>
